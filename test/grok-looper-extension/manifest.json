{
  "manifest_version": 3,
  "name": "Grok Looper",
  "version": "1.0.0",
  "description": "Automatically create loop videos from images on Grok.com/imagine",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://grok.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Grok Looper"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://grok.com/imagine*"],
      "js": ["content/content.js"]
    }
  ]
}
